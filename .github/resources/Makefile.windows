CC=g++
CFLAGS=-std=c++11 -O3 -I. -I/include -Duint="unsigned int"
DEPS_HPP = circom.hpp calcwit.hpp fr.hpp
DEPS_O = main.o calcwit.o fr.o 

all: pol.exe

%.o: %.cpp $(DEPS_HPP)
	$(CC) -Wno-address-of-packed-member -c $< $(CFLAGS)

pol.exe: $(DEPS_O) pol.o
	$(CC) -o pol.exe *.o ./sys/libmman.a -lgmp
